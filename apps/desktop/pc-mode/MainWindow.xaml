<Window x:Class="GSMEDIACUT.PC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="GSMEDIACUT PC Mode"
        Width="1440"
        Height="900"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F0F">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#121212"
                BorderBrush="#222222"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                    <TextBlock Text="GSMEDIACUT"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="PC mode wrapper for the web editor"
                               Margin="0,4,0,0"
                               Foreground="#B7B7B7" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="ReloadButton"
                            Content="Reload"
                            Margin="0,0,10,0"
                            Padding="14,8"
                            Background="#1F6BFF"
                            Foreground="White"
                            BorderBrush="#1F6BFF"
                            Click="ReloadButton_Click" />
                    <Button x:Name="OpenBrowserButton"
                            Content="Open In Browser"
                            Padding="14,8"
                            Background="#1B1B1B"
                            Foreground="White"
                            BorderBrush="#2E2E2E"
                            Click="OpenBrowserButton_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <wv2:WebView2 x:Name="EditorView"
                          DefaultBackgroundColor="Black" />

            <Border x:Name="OverlayPanel"
                    Background="#F7F7F7"
                    Visibility="Collapsed">
                <Grid Margin="28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Web Editor Not Running"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111111" />

                    <TextBlock Grid.Row="1"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               Foreground="#444444"
                               Text="This PC wrapper is designed to show the same GSMEDIACUT web interface inside a desktop window. Start the web editor first, then reload this window." />

                    <StackPanel Grid.Row="2"
                                Margin="0,20,0,0"
                                Orientation="Horizontal">
                        <Button x:Name="StartWebButton"
                                Content="Start apps/web"
                                Margin="0,0,10,0"
                                Padding="16,10"
                                Background="#1F6BFF"
                                Foreground="White"
                                BorderBrush="#1F6BFF"
                                Click="StartWebButton_Click" />
                        <Button x:Name="RetryButton"
                                Content="Retry"
                                Padding="16,10"
                                Background="White"
                                Foreground="#111111"
                                BorderBrush="#CCCCCC"
                                Click="RetryButton_Click" />
                    </StackPanel>

                    <TextBlock Grid.Row="3"
                               x:Name="OverlayStatusText"
                               Margin="0,18,0,0"
                               TextWrapping="Wrap"
                               Foreground="#666666" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#111111"
                BorderBrush="#222222"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <TextBlock x:Name="StatusText"
                       Foreground="#CFCFCF"
                       Text="Initializing desktop wrapper..." />
        </Border>
    </Grid>
</Window>
