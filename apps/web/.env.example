# Environment variables example
# Copy this file to .env.local and update the values as needed

# Node
NODE_ENV=development

# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MARBLE_API_URL=https://api.marblecms.com

# Server
DATABASE_URL="postgresql://opencut:opencut@localhost:5432/opencut"
BETTER_AUTH_SECRET=your_better_auth_secret

UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=example_token

MARBLE_WORKSPACE_KEY=your_workspace_key_here

FREESOUND_CLIENT_ID=your_client_id_here
FREESOUND_API_KEY=your_api_key_here

# Runpod
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_ID=your_runpod_endpoint_id
RUNPOD_API_BASE_URL=https://api.runpod.ai/v2

# Cloudflare R2 temporary uploads for Runpod source files
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_r2_bucket_name

# Public URL that Runpod can reach for self-hosted file downloads.
# Example: https://your-domain.com or https://your-tunnel-url.ngrok-free.app
SERVER_PUBLIC_BASE_URL=https://your-public-server-url

# Local audio separation on the desktop PC
# Install with: pip install audio-separator[gpu]
# Leave AUDIO_SEPARATOR_BINARY as `audio-separator` if it is on PATH
AUDIO_SEPARATOR_BINARY=audio-separator
AUDIO_SEPARATOR_DEFAULT_MODEL=UVR_MDXNET_Main.onnx
